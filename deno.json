{
   "lock": false,
   "version": "0.24.0",
   "lint": {
      "rules": {
         "exclude": ["no-explicit-any", "no-empty"]
      }
   },
   "imports": {
      "@sholvoir/dict-server/": "../dict-server/src/",
      "@sholvoir/generic": "jsr:@sholvoir/generic@^0.4.5",
      "@std/crypto": "jsr:@std/crypto@^1.0.5",
      "hono": "jsr:@hono/hono@^4.12.14",
      "mongodb": "npm:mongodb@^7.1.1"
   },
   "tasks": {
      "build": "deno bundle --check --minify src/main.ts >> dest/main.js",
      "start": "deno run -A --env --watch=src/ src/main.ts"
   }
}
